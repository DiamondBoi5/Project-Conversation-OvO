import pygame
import sys

pygame.init()

# --- WINDOW SETUP ---
WIDTH, HEIGHT = 800, 600
screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("WORK PLEASE")

font = pygame.font.SysFont(None, 32)

# --- LOAD IMAGES ---
image_files = {
     "Normal":"botNeutral.png",
     "Blush": "botBlush.png",
     "Mad": "botMAD.png",
     "Smile": "botSMILE.png"
}
images = {key: pygame.image.load(file) for key, file in image_files.items()}
# Resize images
for key in images:
    images[key] = pygame.transform.scale(images[key], (800, 400))

scene_images = {
    "start": "Normal",
    "choice3": "Blush",      # same image as start
    "choice2": "Mad",
    "choice1": "Smile"      # again same image
}


# --- STORY DATA ---
def load_story(filename):
    story = {}
    current_scene = None

    with open(filename, "r") as f:
        for line in f:
            line = line.strip()
            if not line or line.startswith("#"):
                continue  # skip empty lines/comments

            if line.startswith("[") and line.endswith("]"):
                current_scene = line[1:-1]
                story[current_scene] = {"text": "", "choices": []}
            elif "=" in line and current_scene:
                key, value = line.split("=", 1)
                if key == "text":
                    story[current_scene]["text"] = value
                elif key == "choices":
                    choices = []
                    if value:
                        for c in value.split(","):
                            option, target = c.split(":")
                            choices.append((option.strip(), target.strip()))
                    story[current_scene]["choices"] = choices
    return story

story = load_story("story.txt")

current_scene = "start"

# --- MAIN LOOP ---
running = True
while running:
    screen.fill((0, 0, 0))

    scene = story[current_scene]

    # --- DRAW IMAGE ---
    screen.blit(images[scene_images[current_scene]], (0, 0))

    # --- DRAW TEXT BOX ---
    pygame.draw.rect(screen, (20, 20, 20), (0, 400, 800, 200))
    pygame.draw.rect(screen, (255, 255, 255), (0, 400, 800, 200), 2)

    # --- DRAW DIALOGUE TEXT ---
    text_surface = font.render(scene["text"], True, (255, 255, 255))
    screen.blit(text_surface, (20, 420))

    # --- DRAW CHOICES ---
    for i, choice in enumerate(scene["choices"]):
        choice_text = f"{i+1}. {choice[0]}"
        choice_surface = font.render(choice_text, True, (200, 200, 0))
        screen.blit(choice_surface, (20, 460 + i * 30))

    # --- EVENTS ---
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False

        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_1 and len(scene["choices"]) >= 1:
                current_scene = scene["choices"][0][1]

            elif event.key == pygame.K_2 and len(scene["choices"]) >= 2:
                current_scene = scene["choices"][1][1]

            elif event.key == pygame.K_3 and len(scene["choices"]) >= 3:
                current_scene = scene["choices"][2][1]

    pygame.display.flip()

pygame.quit()
sys.exit()